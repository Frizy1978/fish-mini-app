APP_DEFAULT_CITY=Полярный
APP_DEFAULT_PICKUP_POINT=ул. Советская, 18, павильон у рынка

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_USE_MOCK_API=true
