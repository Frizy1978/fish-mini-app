JWT_SECRET=dev-secret
TELEGRAM_BOT_TOKEN=
TELEGRAM_MINI_APP_URL=http://localhost:3000
TELEGRAM_DEV_MODE=true
TELEGRAM_AUTH_TTL_SECONDS=3600
WOOCOMMERCE_BASE_URL=https://example.com
